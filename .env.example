# App
PORT=8080
ENV=development

# Database (use port 5433 when running Postgres via Docker, 5432 if local)
DATABASE_URL=postgres://vturb:vturb@localhost:5433/vturb

# Redis (use port 6380 when running Redis via Docker, 6379 if local)
REDIS_URL=redis://localhost:6380/0

# Cloudflare Stream
CLOUDFLARE_STREAM_ACCOUNT_ID=your_account_id
CLOUDFLARE_STREAM_API_TOKEN=your_api_token

# Embed
EMBED_API_URL=http://localhost:8080
